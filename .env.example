# Copy to .env and fill in values

# ── Claude credentials (pick ONE option) ──────────────────────────────────────

# Option A: Anthropic API (simplest)
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: Google Vertex AI
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# CLOUD_ML_REGION=global
# VERTEX_SA_KEY_PATH=/path/to/credentials.json
#   (use ADC: ~/.config/gcloud/application_default_credentials.json
#    or a service account key JSON file)

# ── Model ─────────────────────────────────────────────────────────────────────

CLAUDE_MODEL=claude-sonnet-4-6

# ── Temporal ──────────────────────────────────────────────────────────────────

TEMPORAL_ADDRESS=localhost:7233

# ── Docker images (built via `make build` / `make build-qa`) ─────────────────

CLAUDE_IMAGE=daedalus:latest
CLAUDE_QA_IMAGE=daedalus-qa:latest

# ── Notifications (optional) ──────────────────────────────────────────────────

# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# EVENT_WEBHOOK_URL=https://your-endpoint.com/events
# TEMPORAL_UI_URL=http://localhost:8233

# ── Ticket-driven execution ───────────────────────────────────────────────────

# Directory containing ticket markdown files (used by run_ticket.py / make run-ticket / make backlog)
# DAEDALUS_TICKETS_DIR=/path/to/knowledge/ado

# ── PR review (make review PR=42) ────────────────────────────────────────────
# GitHub personal access token for the pr_reviewer agent (GitHub-only; ADO on roadmap)
# GITHUB_TOKEN=ghp_...

# ── PR creation ───────────────────────────────────────────────────────────────
# Auto-detected from remote URL. Override if needed: github | ado | none
# DAEDALUS_PR_PROVIDER=ado

# Required for ADO PR creation (maps to AZURE_DEVOPS_EXT_PAT internally)
# AZURE_DEVOPS_PAT=your-pat-here

# Target branch for raised PRs (default: develop)
# DAEDALUS_BASE_BRANCH=main     # default: main
